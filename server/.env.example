# Backend-only runtime configuration.
PORT=8080
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_WRITE_MAX=60
DATABASE_URL=postgres://dev:dev@localhost/changeMe
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
TOKEN_SECRET=changeMe
AUTH_ENABLED=false
AUTH_PROVIDER=auth0
AUTH_ISSUER=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=
AUTH_LOGIN_REDIRECT_URI=
AUTH_LOGOUT_REDIRECT_URI=
SESSION_SECRET=
SESSION_TTL_SECONDS=604800
# Use `none` for split-host production (frontend and API on different origins).
SESSION_COOKIE_SAME_SITE=lax

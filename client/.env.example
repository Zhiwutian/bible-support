# Frontend-only runtime/build configuration.
# Set this for split hosting (for example, Render API + Vercel frontend).
# Example: https://your-api.onrender.com
VITE_API_BASE_URL=

# Feature flag for phased Reader comfort controls rollout.
# true  -> show Reader settings and break reminder controls
# false -> keep Reader core chapter experience without comfort controls UI
VITE_READER_COMFORT_ENABLED=true
